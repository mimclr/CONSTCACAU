name: Build .exe - Labor Rural

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:

jobs:
  build-windows:
    runs-on: windows-latest
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Instalar dependencias
        run: |
          python -m pip install --upgrade pip
          pip install openpyxl pyinstaller

      - name: Build .exe
        run: pyinstaller build.spec

      - name: Upload artefato
        uses: actions/upload-artifact@v4
        with:
          name: Analise_Consistencia_LaborRural
          path: dist/Analise_Consistencia_LaborRural.exe

      - name: Criar Release
        if: startsWith(github.ref, 'refs/tags/')
        uses: softprops/action-gh-release@v2
        with:
          files: dist/Analise_Consistencia_LaborRural.exe
          name: "Labor Rural ${{ github.ref_name }}"
          body: |
            ## Analise de Consistencia - Labor Rural
            Baixe e execute o .exe diretamente no Windows.
            Nenhuma instalacao necessaria.
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
